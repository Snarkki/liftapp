DEBUG=True
FORCE_HTTPS=False
SECRET_KEY=replace-me

# Comma-separated Django host allowlist used in production.
ALLOWED_HOSTS=your-host.example.com,localhost,127.0.0.1

# Static file paths (set these to match your Nginx /static/ alias)
# Example for Nginx alias /var/www/liftapp/static/:
# STATIC_ROOT=/var/www/liftapp/static
# WEBPACK_MANIFEST_PATH=/var/www/liftapp/static/manifest.json

PGHOST=localhost
PGPORT=5432
PGDATABASE=liftapp
PGUSER=postgres
PGPASSWORD=postgres

# Optional fallback host appended to ALLOWED_HOSTS when ALLOWED_HOSTS is unset.
TAILSCALE_HOST_NAME=your-host.example.com
